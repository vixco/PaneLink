{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaneLink",
  "version": "0.1.21",
  "identifier": "com.vixco.panelink",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PaneLink",
        "width": 1280,
        "height": 820,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBQUE0QkQ2MTU1NDQxQkEKUldTNlFWUVYxa3VxdW9WaEtUY1B0Q2pTN1dHdnh4OWhVeU9PZG42UVd4RSt0NTFVZTFRQ0dta1cK",
      "endpoints": [
        "https://github.com/vixco/PaneLink/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
